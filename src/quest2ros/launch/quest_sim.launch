<launch>
    <!-- Quest VR + Fast-Drone-250 simulation launch -->
    <!-- Usage: roslaunch quest2ros quest_sim.launch -->
    <!--        roslaunch quest2ros quest_sim.launch tcp_ip:=192.168.x.x -->

    <arg name="tcp_ip" default="0.0.0.0" />
    <arg name="tcp_port" default="10000" />

    <!-- Main drone simulation -->
    <include file="$(find ego_planner)/launch/single_run_in_sim.launch" />

    <!-- ROS TCP Endpoint for Quest VR communication -->
    <include file="$(find ros_tcp_endpoint)/launch/endpoint.launch">
        <arg name="tcp_ip" value="$(arg tcp_ip)"/>
        <arg name="tcp_port" value="$(arg tcp_port)"/>
    </include>

    <!-- VR -> Drone bridge -->
    <node pkg="quest2ros" name="quest_drone_bridge" type="quest_drone_bridge.py" output="screen">
        <param name="scale" value="30.0" />
        <param name="offset_x" value="0.0" />
        <param name="offset_y" value="0.0" />
        <param name="offset_z" value="0.5" />
    </node>

    <!-- Flight data dashboard (Quest浏览器访问 http://<Windows-WiFi-IP>:8888) -->
    <node pkg="quest2ros" name="flight_dashboard" type="flight_dashboard.py" output="screen">
        <param name="port" value="8888" />
    </node>

</launch>
